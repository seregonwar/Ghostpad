+static uint32_t btc_ps_crc32(uint8_t seed,
+                              const uint8_t *data,
+                              size_t len)
+{
+    uint32_t crc = 0xFFFFFFFFUL;
+    crc = btc_crc32_le_update(crc, &seed, 1U);
+    crc = btc_crc32_le_update(crc, data, len);
+    return ~crc;
+}
